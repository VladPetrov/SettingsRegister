{
  "Application": {
    "AppScaling": false,
    "ManifestImportLockTimeoutSeconds": 30,
    "ManifestCacheExpirationSeconds": 300,
    "ConfigurationCacheExpirationSeconds": 300,
    "ConfigurationChangeCacheExpirationSeconds": 300
  },
  "Auth": {
    "DevSigningKey": "dev-only-signing-key-change-before-production",
    "Issuer": "SettingsRegister",
    "Audience": "SettingsRegister.Api",
    "TokenLifetimeMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

