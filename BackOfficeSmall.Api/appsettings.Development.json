{
  "Application": {
    "AppScaling": false,
    "ManifestImportLockTimeoutSeconds": 30
  },
  "Auth": {
    "DevSigningKey": "dev-only-signing-key-change-before-production",
    "Issuer": "BackOfficeSmall",
    "Audience": "BackOfficeSmall.Api",
    "TokenLifetimeMinutes": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
