@startuml
title Configuration Change Tracker - Domain Model

skinparam classAttributeIconSize 0

class ManifestDomainRoot {
  +Guid ManifestId
  +string Name
  +int Version
  +int LayerCount
  +DateTime CreatedAtUtc
  +string CreatedBy
  +List<ManifestSettingDefinition> SettingDefinitions
  +List<ManifestOverridePermission> OverridePermissions
  +Validate()
}

class ManifestValueObject {
  +Guid ManifestId
  +string Name
  +int Version
  +int LayerCount
  +DateTime CreatedAtUtc
  +string CreatedBy
  +IReadOnlyList<ManifestSettingDefinition> SettingDefinitions
  +IReadOnlyList<ManifestOverridePermission> OverridePermissions
  +HasSetting(string settingKey)
  +RequiresCriticalNotification(string settingKey)
  +CanOverride(string settingKey, int layerIndex)
}

class ManifestEntity {
  +Guid ManifestId
  +string Name
  +int Version
  +int LayerCount
  +DateTime CreatedAtUtc
  +string CreatedBy
  +List<ManifestSettingDefinitionEntity> SettingDefinitions
  +List<ManifestOverridePermissionEntity> OverridePermissions
}

class ManifestDto {
  +string Name
  +int LayerCount
  +string CreatedBy
  +IReadOnlyList<ManifestFileSettingDefinitionDto> SettingDefinitions
  +IReadOnlyList<ManifestFileOverridePermissionDto> OverridePermissions
}

class ManifestSettingDefinition {
  +string SettingKey
  +bool RequiresCriticalNotification
  +Validate()
}

class ManifestOverridePermission {
  +string SettingKey
  +int LayerIndex
  +bool CanOverride
  +Validate()
}

class ConfigInstance {
  +Guid ConfigInstanceId
  +string Name
  +Guid ManifestId
  +DateTime CreatedAtUtc
  +string CreatedBy
  +SetValue(string settingKey, int layerIndex, string? value)
  +Validate()
}

class SettingCell {
  +string SettingKey
  +int LayerIndex
  +string? Value
  +Validate()
}

class ConfigChange {
  +Guid Id
  +Guid ConfigInstanceId
  +string SettingKey
  +int LayerIndex
  +ConfigOperation Operation
  +string? BeforeValue
  +string? AfterValue
  +string ChangedBy
  +DateTime ChangedAtUtc
  +Validate()
}

enum ConfigOperation {
  Add
  Update
  Delete
}

class ManifestService {
  +ImportManifest(ManifestImportRequest request)
  +GetById(Guid manifestId)
  +GetLatestByName(string name)
}

class ConfigInstanceService {
  +CreateInstance(ConfigInstance instance)
  +GetById(Guid instanceId)
  +List()
  +Delete(Guid instanceId)
  +SetCellValue(Guid instanceId, string settingKey, int layerIndex, string? value)
}

class ConfigChangeQueryService {
  +GetChangeById(Guid id)
  +ListChanges(DateTime? fromUtc, DateTime? toUtc, ConfigOperation? operation)
}

interface IManifestRepository {
  +Add(ManifestDomainRoot manifest)
  +GetById(Guid manifestId) : ManifestValueObject
  +GetLatestByName(string name) : ManifestValueObject
}

interface IConfigInstanceRepository {
  +Add(ConfigInstance instance)
  +GetById(Guid instanceId)
  +List()
  +Update(ConfigInstance instance)
  +Delete(Guid instanceId)
}

interface IConfigChangeRepository {
  +Add(ConfigChange change)
  +GetById(Guid id)
  +List(DateTime? fromUtc, DateTime? toUtc, ConfigOperation? operation)
}

interface IMonitoringNotifier {
  +NotifyCriticalChangeAsync(ConfigChange change)
}

ManifestDomainRoot "1" *-- "*" ManifestSettingDefinition
ManifestDomainRoot "1" *-- "*" ManifestOverridePermission
ManifestValueObject "1" *-- "*" ManifestSettingDefinition
ManifestValueObject "1" *-- "*" ManifestOverridePermission
ConfigInstance "1" *-- "*" SettingCell
ConfigInstance --> ManifestValueObject : references by ManifestId
ConfigChange --> ConfigInstance
ManifestEntity --> ManifestValueObject : hydrated to
ManifestDto --> ManifestDomainRoot : mapped to

ManifestService --> IManifestRepository
ConfigInstanceService --> IManifestRepository : validates structure/rules
ConfigInstanceService --> IConfigInstanceRepository
ConfigInstanceService --> IConfigChangeRepository : writes audit log
ConfigInstanceService --> IMonitoringNotifier : on critical settings
ConfigChangeQueryService --> IConfigChangeRepository

note right of ManifestDomainRoot
Responsibilities:
1) Mutable domain root used for write-side validation.
2) Validate() enforces shape and invariant checks.
end note

note right of ManifestValueObject
Responsibilities:
1) Immutable read model for manifest behavior queries.
2) Exposes HasSetting / CanOverride / RequiresCriticalNotification.
3) Created via hydration from persistence entity.
end note

note right of ManifestEntity
Responsibilities:
1) Persistence-only representation.
2) No domain behavior and no Validate() method.
end note

note right of ConfigInstance
Invariants:
1) Name is unique.
2) ManifestId must exist.
3) Cells must match manifest keys and layer range.
4) Override allowed only by manifest permissions.
5) No duplicate (SettingKey, LayerIndex) cell.
end note

note right of ConfigChange
Invariants:
1) Id is immutable and unique.
2) ChangedAtUtc is UTC and immutable.
3) Operation rules:
   - Add: AfterValue required, BeforeValue absent.
   - Update: BeforeValue and AfterValue required.
   - Delete: BeforeValue required, AfterValue absent.
4) Critical notification is derived from manifest setting definition.
end note

@enduml
