@startuml
title Configuration Change Tracker - Domain Model

skinparam classAttributeIconSize 0

class ManifestDomainRoot {
  +Guid ManifestId
  +string Name
  +int Version
  +int LayerCount
  +DateTime CreatedAtUtc
  +string CreatedBy
  +IReadOnlyList<ManifestSettingDefinition> SettingDefinitions
  +IReadOnlyList<ManifestOverridePermission> OverridePermissions
  +ReplaceSettingDefinitions(IEnumerable<ManifestSettingDefinition> settingDefinitions)
  +ReplaceOverridePermissions(IEnumerable<ManifestOverridePermission> overridePermissions)
  +Validate()
}

class ManifestValueObject {
  +Guid ManifestId
  +string Name
  +int Version
  +int LayerCount
  +DateTime CreatedAtUtc
  +string CreatedBy
  +IReadOnlyList<ManifestSettingDefinition> SettingDefinitions
  +IReadOnlyList<ManifestOverridePermission> OverridePermissions
  +HasSetting(string settingKey)
  +RequiresCriticalNotification(string settingKey)
  +CanOverride(string settingKey, int layerIndex)
}

class ManifestEntity {
  +Guid ManifestId
  +string Name
  +int Version
  +int LayerCount
  +DateTime CreatedAtUtc
  +string CreatedBy
  +List<ManifestSettingDefinitionEntity> SettingDefinitions
  +List<ManifestOverridePermissionEntity> OverridePermissions
}

class ManifestDto {
  +string Name
  +int LayerCount
  +string CreatedBy
  +IReadOnlyList<ManifestFileSettingDefinitionDto> SettingDefinitions
  +IReadOnlyList<ManifestFileOverridePermissionDto> OverridePermissions
}

class ManifestSettingDefinition {
  +string SettingKey
  +bool RequiresCriticalNotification
  +Validate()
}

class ManifestOverridePermission {
  +string SettingKey
  +int LayerIndex
  +bool CanOverride
  +Validate()
}

class ConfigurationInstance {
  +Guid ConfigurationId
  +string Name
  +Guid ManifestId
  +ManifestValueObject Manifest
  +DateTime CreatedAtUtc
  +string CreatedBy
  +GetValue(string settingKey, int layerIndex)
  +IReadOnlyList<ConfigurationSettingRow> GetSettings()
  +SetValue(string settingKey, int layerIndex, string? value)
  +Clone()
  +Validate()
}

class SettingCell {
  +string SettingKey
  +int LayerIndex
  +string? Value
  +Validate()
}

class ConfigurationSettingRow {
  +int LayerIndex
  +IReadOnlyList<ConfigurationSettingValue> Values
}

class ConfigurationSettingValue {
  +string SettingKey
  +string? Value
  +bool IsExplicitValue
  +bool CanOverride
  +bool RequiresCriticalNotification
}

class ConfigurationChange {
  +Guid Id
  +Guid ConfigurationId
  +ConfigurationChangeEventType EventType
  +string SettingKey
  +int LayerIndex
  +ConfigurationOperation Operation
  +string? BeforeValue
  +string? AfterValue
  +string ChangedBy
  +DateTime ChangedAtUtc
  +Validate()
}

class MonitoringNotifierOutboxMessage {
  +Guid Id
  +string DedupeKey
  +Guid ConfigurationChangeId
  +Guid ConfigurationId
  +string SettingKey
  +int LayerIndex
  +ConfigurationOperation Operation
  +string? BeforeValue
  +string? AfterValue
  +string ChangedBy
  +DateTime ChangedAtUtc
  +MonitoringNotificationOutboxStatus Status
  +int AttemptCount
  +DateTime CreatedAtUtc
  +DateTime? LastAttemptAtUtc
  +DateTime? SentAtUtc
  +string? LastError
  +ToNotificationMessage()
  +MarkSent(DateTime attemptedAtUtc)
  +MarkFailed(DateTime attemptedAtUtc, string? error)
}

class MonitoringNotificationMessage {
  +Guid OutboxMessageId
  +string DedupeKey
  +Guid ConfigurationChangeId
  +Guid ConfigurationId
  +string SettingKey
  +int LayerIndex
  +ConfigurationOperation Operation
  +string? BeforeValue
  +string? AfterValue
  +string ChangedBy
  +DateTime ChangedAtUtc
}

enum ConfigurationOperation {
  Add
  Update
  Delete
}

enum ConfigurationChangeEventType {
  ConfigurationSetting
  ManifestImport
}

enum MonitoringNotificationOutboxStatus {
  Pending
  Sent
  Failed
}

class ManifestService {
  +ImportManifest(ManifestImportRequest request)
  +GetById(Guid manifestId)
  +List()
  +List(string? name)
}

class ConfigurationInstanceService {
  +CreateInstance(ConfigurationInstance instance)
  +GetById(Guid instanceId)
  +List()
  +Delete(Guid instanceId, string deletedBy)
  +SetCellValue(Guid instanceId, string settingKey, int layerIndex, string? value)
}

class ConfigurationChangeQueryService {
  +GetChangeById(Guid id)
  +ListChanges(DateTime? fromUtc, DateTime? toUtc, ConfigurationOperation? operation, string? cursor, int? pageSize)
}

class OutboxDispatchService {
  +StartAsync(CancellationToken cancellationToken)
  +NotifyChanges()
}

interface IManifestRepository {
  +Add(ManifestDomainRoot manifest)
  +GetById(Guid manifestId) : ManifestValueObject
  +List() : IReadOnlyList<ManifestValueObject>
  +List(string? name) : IReadOnlyList<ManifestValueObject>
}

interface IConfigurationRepository {
  +Add(ConfigurationInstance instance)
  +GetById(Guid instanceId)
  +List()
  +Update(ConfigurationInstance instance)
  +Delete(Guid instanceId)
}

interface IConfigurationChangeRepository {
  +Add(ConfigurationChange change)
  +GetById(Guid id)
  +List(DateTime? fromUtc, DateTime? toUtc, ConfigurationOperation? operation, DateTime? afterChangedAtUtc, Guid? afterId, int take)
}

interface IMonitoringNotifierOutboxRepository {
  +Add(MonitoringNotifierOutboxMessage outboxMessage)
  +GetById(Guid id)
  +List(MonitoringNotificationOutboxStatus? status)
  +ListDispatchCandidates(int take)
  +Update(MonitoringNotifierOutboxMessage outboxMessage)
}

interface IMonitoringNotifier {
  +SendAsync(MonitoringNotificationMessage message) : bool
  +IsAvailableAsync() : bool
}

interface IDomainLock {
  +TryTakeLock(string key, TimeSpan timeout) : IDomainLockLease
}

interface IDomainLockLease {
  +Dispose()
}

ManifestDomainRoot "1" *-- "*" ManifestSettingDefinition
ManifestDomainRoot "1" *-- "*" ManifestOverridePermission
ManifestValueObject "1" *-- "*" ManifestSettingDefinition
ManifestValueObject "1" *-- "*" ManifestOverridePermission
ConfigurationInstance "1" *-- "*" SettingCell
ConfigurationInstance "1" *-- "*" ConfigurationSettingRow
ConfigurationSettingRow "1" *-- "*" ConfigurationSettingValue
ConfigurationInstance "1" *-- "1" ManifestValueObject
ConfigurationChange --> ConfigurationInstance
MonitoringNotifierOutboxMessage --> ConfigurationChange
MonitoringNotifierOutboxMessage --> MonitoringNotificationMessage : maps to
ManifestEntity --> ManifestValueObject : hydrated to
ManifestDto --> ManifestDomainRoot : mapped to

ManifestService --> IManifestRepository
ManifestService --> IConfigurationChangeRepository : writes audit log
ManifestService --> IMonitoringNotifierOutboxRepository : writes critical outbox intent
ManifestService --> OutboxDispatchService : triggers one-shot signal
ManifestService --> IDomainLock : import serialization
ConfigurationInstanceService --> IManifestRepository : resolves manifest for instance creation
ConfigurationInstanceService --> IConfigurationRepository
ConfigurationInstanceService --> IConfigurationChangeRepository : writes audit log
ConfigurationInstanceService --> IMonitoringNotifierOutboxRepository : writes critical outbox intent
ConfigurationInstanceService --> OutboxDispatchService : triggers one-shot drain
ConfigurationInstanceService --> IDomainLock : per-instance serialization
ConfigurationChangeQueryService --> IConfigurationChangeRepository
OutboxDispatchService --> IMonitoringNotifierOutboxRepository : reads and updates outbox
OutboxDispatchService --> IMonitoringNotifier : dispatches external transport

note right of ManifestDomainRoot
Responsibilities:
1) Write-side domain root with controlled mutation APIs.
2) Validate() enforces shape and invariant checks.
end note

note right of ManifestValueObject
Responsibilities:
1) Immutable read model for manifest behavior queries.
2) Exposes HasSetting / CanOverride / RequiresCriticalNotification.
3) Created via hydration from persistence entity.
end note

note right of ManifestEntity
Responsibilities:
1) Persistence-only representation.
2) No domain behavior and no Validate() method.
end note

note right of ConfigurationInstance
Invariants:
1) Name is unique.
2) Holds manifest behavior object for rule checks.
3) Cells must match manifest keys and layer range.
4) Override allowed only by manifest permissions.
5) No duplicate (SettingKey, LayerIndex) cell.
end note

note right of ConfigurationChange
Invariants:
1) Id is immutable and unique.
2) ChangedAtUtc is UTC and immutable.
3) EventType defines operation/value rules:
   - ConfigurationSetting: Add/Update/Delete semantics.
   - ManifestImport: Add only, AfterValue required, BeforeValue absent.
4) Critical notification is derived from manifest setting definition.
end note

note right of MonitoringNotifierOutboxMessage
Responsibilities:
1) Immutable notification intent snapshot tied to ConfigurationChange.
2) Tracks delivery state machine: Pending -> Sent or Failed.
3) Stores retry metadata and last transport error for resilient dispatch.
end note

@enduml


